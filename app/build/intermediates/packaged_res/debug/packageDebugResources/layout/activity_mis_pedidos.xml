<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/verde_primario"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/logoapp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AgroConecta"
                android:textColor="@color/blanco"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Pedidos"
                android:textColor="#AAFFCC"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦"
            android:textSize="24sp"/>

    </LinearLayout>

    <!-- FILTROS -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        card_view:cardCornerRadius="16dp"
        card_view:cardElevation="2dp"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILTRAR POR ESTADO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spFiltroEstadoPedidos"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HISTORIAL DE PEDIDOS"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:textColor="@color/texto_secundario"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <!-- RecyclerView -->
    <ProgressBar
        android:id="@+id/progressMisPedidos"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#25632D"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvEmptyMisPedidos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="No tienes pedidos aún"
        android:textSize="15sp"
        android:visibility="gone"/>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMisPedidos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

</LinearLayout>