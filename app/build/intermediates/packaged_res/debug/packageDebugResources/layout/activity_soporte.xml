<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crema"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/verde_primario"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBackSoporte"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Volver"
            app:tint="@color/blanco"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Soporte Técnico"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="80dp"
            android:gravity="center_horizontal">

            <!-- Icono -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛠️"
                android:textSize="72sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Necesitas ayuda?"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/texto_primario"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nuestro equipo está disponible para ayudarte con cualquier problema o consulta sobre AgroConecta."
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"
                android:gravity="center"
                android:layout_marginBottom="32dp"
                android:lineSpacingMultiplier="1.4"/>

            <!-- CARD REPORTE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/blanco"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Describe tu problema"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/texto_primario"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tipo de problema"
                        style="@style/TextInputOutlined"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTipoProblema"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="text"
                            android:imeOptions="actionNext"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Describe el problema en detalle"
                        style="@style/TextInputOutlined"
                        android:layout_marginBottom="20dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescripcionProblema"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:inputType="textMultiLine"
                            android:gravity="top"
                            android:imeOptions="actionDone"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón WhatsApp -->
                    <Button
                        android:id="@+id/btnEnviarWhatsApp"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="📲 Enviar por WhatsApp"
                        android:backgroundTint="#25D366"
                        android:textColor="@color/blanco"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        style="@style/BtnPrimario"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD INFO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/verde_superficial">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ Información de contacto"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/verde_primario"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 WhatsApp: +503 7147-0646"
                        android:textSize="14sp"
                        android:textColor="@color/texto_primario"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐 Horario: Lunes a Viernes 8am - 5pm"
                        android:textSize="14sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏫 ITCA-FEPADE"
                        android:textSize="14sp"
                        android:textColor="@color/texto_secundario"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
