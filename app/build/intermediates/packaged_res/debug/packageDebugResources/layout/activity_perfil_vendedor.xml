<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crema"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/verde_primario"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/btnBackPerfilVendedor"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Volver"
            app:tint="@color/blanco" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Mi Perfil"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="250dp">

            <!-- FOTO DE PERFIL -->
            <FrameLayout
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginBottom="8dp">

                <!-- Foto (se muestra si hay URL) -->
                <ImageView
                    android:id="@+id/ivFotoPerfilVendedor"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:visibility="gone"
                    android:contentDescription="Foto de perfil"/>

                <!-- Inicial (fallback cuando no hay foto) -->
                <TextView
                    android:id="@+id/tvAvatarVendedorPerfil"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:gravity="center"
                    android:text="V"
                    android:textColor="@color/carbon"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:elevation="4dp"/>

                <!-- Botón cámara sobre la foto -->
                <TextView
                    android:id="@+id/btnCambiarFotoVendedor"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_boton_verde"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="16sp"
                    android:elevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Cambiar foto"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvRolVendedorPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vendedor"
                android:textColor="@color/verde_primario"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <!-- CARD EDITAR DATOS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información Personal"
                        android:textColor="@color/texto_primario"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre completo"
                        style="@style/TextInputOutlined"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombreVendedorPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPersonName"
                            android:imeOptions="actionNext"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Correo electrónico"
                        style="@style/TextInputOutlined"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCorreoVendedorPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textEmailAddress"
                            android:imeOptions="actionNext"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Teléfono (WhatsApp)"
                        style="@style/TextInputOutlined"
                        android:layout_marginBottom="4dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTelefonoVendedorPerfil"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="phone"
                            android:imeOptions="actionDone"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Este número se usará para que los compradores te contacten por WhatsApp"
                        android:textColor="@color/texto_tenue"
                        android:textSize="12sp"
                        android:layout_marginBottom="20dp"
                        android:layout_marginTop="4dp"/>

                    <Button
                        android:id="@+id/btnGuardarPerfilVendedor"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="💾 Guardar cambios"
                        android:backgroundTint="@color/verde_primario"
                        android:textColor="@color/blanco"
                        android:textStyle="bold"
                        style="@style/BtnPrimario"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD CAMBIAR CONTRASEÑA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/blanco"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cambiar Contraseña"
                        android:textColor="@color/texto_primario"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nueva contraseña"
                        style="@style/TextInputOutlined"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/verde_primario"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNuevaPasswordVendedor"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword"
                            android:imeOptions="actionNext"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Confirmar nueva contraseña"
                        style="@style/TextInputOutlined"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/verde_primario"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etConfirmarPasswordVendedor"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnCambiarPasswordVendedor"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="🔒 Cambiar contraseña"
                        android:backgroundTint="@color/dorado_medio"
                        android:textColor="@color/carbon"
                        android:textStyle="bold"
                        style="@style/BtnPrimario"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnLogoutVendedor"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:text="Cerrar Sesión"
                android:backgroundTint="@color/rojo_error"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                style="@style/BtnPrimario" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
