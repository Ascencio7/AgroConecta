<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:background="#25632d"
            android:paddingHorizontal="20dp"
            android:paddingTop="44dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/logoapp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AgroConecta"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi carrito de compras"
                    android:textColor="#D4B896"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Badge carrito -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒"
                android:textSize="26sp"/>

        </LinearLayout>

        <!-- Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRODUCTOS SELECCIONADOS"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textStyle="bold"
            android:textColor="#5C4A30"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCarrito"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"/>

        <!-- Footer con total y botón -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="0dp"
            card_view:cardElevation="12dp"
            card_view:cardBackgroundColor="#2C1F14">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <!-- Línea separadora dorada -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#E8A020"
                    android:layout_marginBottom="16dp"/>

                <!-- Total + Items -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL A PAGAR"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="#D4B896"/>

                        <TextView
                            android:id="@+id/tvTotalCarrito"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="#E8A020"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <!-- Items badge -->
                    <LinearLayout
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#E8A020">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ITEMS"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textColor="#2C1F14"/>

                        <TextView
                            android:id="@+id/tvCantidadItems"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#2C1F14"
                            android:gravity="center"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Botón confirmar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmarPedido"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="CONFIRMAR PEDIDO"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#25632D"
                    android:letterSpacing="0.05"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</LinearLayout>
