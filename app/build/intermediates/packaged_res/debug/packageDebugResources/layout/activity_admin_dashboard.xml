<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorAdmin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/crema">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/verde_primario"
            android:paddingTop="12dp"
            android:paddingBottom="14dp"
            android:paddingHorizontal="20dp"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/logoapp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Logo"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvWelcomeAdmin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Bienvenido!"
                        android:textColor="@color/blanco"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                    <TextView
                        android:id="@+id/tvAdminSubtitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Panel de Administración"
                        android:textColor="#AAFFCC"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Avatar Logout -->
                <TextView
                    android:id="@+id/tvAvatarAdmin"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/carbon"
                    android:background="@drawable/bg_avatar_circle"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CONTENIDO -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BIENVENIDO"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:textColor="@color/texto_secundario"/>
                        <TextView
                            android:id="@+id/txtTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Panel de Control ⚙️"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_primario"
                            android:layout_marginTop="6dp"/>
                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:background="@color/dorado"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gestiona usuarios, productos y visualiza reportes del sistema."
                            android:textSize="13sp"
                            android:textColor="@color/texto_secundario"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Label sección -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPCIONES DE GESTIÓN"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginBottom="12dp"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuarios"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="28sp"
                            android:layout_marginEnd="16dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Usuarios"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/texto_primario"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ver y gestionar cuentas"
                                android:textSize="11sp"
                                android:textColor="@color/texto_secundario"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="@color/dorado"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProductos"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦"
                            android:textSize="28sp"
                            android:layout_marginEnd="16dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Productos"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/texto_primario"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Administrar catálogo"
                                android:textSize="11sp"
                                android:textColor="@color/texto_secundario"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="@color/dorado"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReportes"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="28sp"
                            android:layout_marginEnd="16dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reportes"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/texto_primario"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estadísticas y métricas"
                                android:textSize="11sp"
                                android:textColor="@color/texto_secundario"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="28sp"
                            android:textColor="@color/dorado"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- BARRA DE NAVEGACIÓN -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavAdmin"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:background="@color/blanco"
            android:elevation="16dp"
            app:menu="@menu/admin_nav_menu"
            app:labelVisibilityMode="labeled"
            style="@style/Widget.App.BottomNavigationView"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
