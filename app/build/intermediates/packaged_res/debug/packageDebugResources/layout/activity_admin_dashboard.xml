<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorAdmin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/crema"
        android:orientation="vertical"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/verde_primario"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Logo"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logoapp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWelcomeAdmin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="¡Bienvenido!"
                        android:textColor="@color/blanco"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminSubtitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Panel de Administración"
                        android:textColor="#AAFFCC"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Avatar Logout -->
                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:id="@+id/tvAvatarAdmin"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="@color/carbon"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:id="@+id/ivAvatarFotoAdmin"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_avatar_circle"
                        android:visibility="gone"
                        android:contentDescription="Foto de perfil"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- CONTENIDO -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="676dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="BIENVENIDO"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Panel de Control ⚙️"
                            android:textColor="@color/texto_primario"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="10dp"
                            android:background="@color/dorado" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gestiona usuarios, productos y visualiza reportes del sistema."
                            android:textColor="@color/texto_secundario"
                            android:textSize="13sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Label sección -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.12"
                    android:text="OPCIONES DE GESTIÓN"
                    android:textColor="@color/texto_secundario"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuarios"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:text="👥"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Usuarios"
                                android:textColor="@color/texto_primario"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Ver y gestionar cuentas"
                                android:textColor="@color/texto_secundario"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/dorado"
                            android:textSize="28sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProductos"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:text="📦"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Productos"
                                android:textColor="@color/texto_primario"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Administrar catálogo"
                                android:textColor="@color/texto_secundario"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/dorado"
                            android:textSize="28sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReportes"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:text="📊"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reportes"
                                android:textColor="@color/texto_primario"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Estadísticas y métricas"
                                android:textColor="@color/texto_secundario"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/dorado"
                            android:textSize="28sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavAdmin"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayout2"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/admin_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
