<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- FILA 1: Avatar + Nombre + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Avatar (foto o iniciales) -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/txtAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:gravity="center"
                    android:text="U"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/carbon"
                    android:background="@drawable/bg_avatar_circle"/>

                <ImageView
                    android:id="@+id/ivFotoUsuario"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:visibility="gone"
                    android:contentDescription="Foto de perfil"/>
            </FrameLayout>

            <!-- Nombre + Rol -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_primario"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/txtRol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario"
                    android:textSize="12sp"
                    android:textColor="@color/texto_tenue"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Badge estado -->
            <TextView
                android:id="@+id/txtEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/verde_primario"
                android:background="@drawable/bg_badge_verde"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gris_borde"
            android:layout_marginBottom="12dp"/>

        <!-- FILA 2: Correo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORREO"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/texto_tenue"
            android:letterSpacing="0.05"/>
        <TextView
            android:id="@+id/txtCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="correo@ejemplo.com"
            android:textSize="14sp"
            android:textColor="@color/texto_primario"
            android:layout_marginBottom="8dp"/>

        <!-- FILA 3: Teléfono -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TELÉFONO"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/texto_tenue"
            android:letterSpacing="0.05"/>
        <TextView
            android:id="@+id/txtTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="7777-8888"
            android:textSize="14sp"
            android:textColor="@color/texto_primario"
            android:layout_marginBottom="16dp"/>

        <!-- FILA 4: Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditar"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="0.8"
                android:layout_marginEnd="6dp"
                android:text="Editar"
                android:textSize="11sp"
                android:textColor="@color/verde_primario"
                app:backgroundTint="@color/verde_superficial"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="@color/verde_primario"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                android:paddingHorizontal="4dp"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminar"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1.2"
                android:layout_marginStart="6dp"
                android:text="Desactivar"
                android:textSize="11sp"
                android:textColor="@color/rojo_error"
                app:backgroundTint="#FFF1F0"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/rojo_error"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                android:paddingHorizontal="4dp"
                style="@style/Widget.Material3.Button.TonalButton"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
