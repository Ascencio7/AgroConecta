<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- LOGO -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="180dp"
        android:layout_height="120dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"
        android:contentDescription="@string/content_desc_logo" />

    <!-- NOMBRE APP -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/blanco"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- CARGANDO (Visible inicialmente) -->
    <ProgressBar
        android:id="@+id/pbCargando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/blanco"
        android:layout_marginBottom="24dp" />

    <!-- MENSAJE DE ERROR (Oculto inicialmente) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/blanco"
        android:layout_marginBottom="32dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emoji_alerta"
                android:textSize="48sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/msg_sin_conexion"
                android:textColor="@color/texto_primario"
                android:textSize="17sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- BOTÓN ACEPTAR (Oculto inicialmente) -->
    <Button
        android:id="@+id/btnAceptar"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_aceptar"
        android:textColor="@color/verde_primario"
        app:backgroundTint="@color/blanco"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
