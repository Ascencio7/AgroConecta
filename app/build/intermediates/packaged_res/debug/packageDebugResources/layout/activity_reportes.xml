<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorReportes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutReportes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/crema"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/verde_primario"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingHorizontal="20dp"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivHeaderLogoReportes"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/logoapp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Logo"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AgroConecta"
                        android:textColor="@color/blanco"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reportes y Estadísticas 📊"
                        android:textColor="#AAFFCC"
                        android:textSize="11sp"
                        android:textAllCaps="true"/>
                </LinearLayout>

                <!-- Avatar Logout -->
                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tvAvatarAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/carbon"
                        android:background="@drawable/bg_avatar_circle"/>

                    <ImageView
                        android:id="@+id/ivAvatarFotoAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_avatar_circle"
                        android:visibility="gone"
                        android:contentDescription="Foto de perfil"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecciona el reporte que deseas generar y descargar:"
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="24dp"/>

            <!-- Reporte Usuarios -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnReporteUsuarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥"
                        android:textSize="30sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reporte de Usuarios"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_primario"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Listado completo de usuarios"
                            android:textSize="12sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/stat_sys_download"
                        app:tint="@color/dorado"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Reporte Productos -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnReporteProductos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦"
                        android:textSize="30sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reporte de Productos"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_primario"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inventario actual de productos"
                            android:textSize="12sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/stat_sys_download"
                        app:tint="@color/dorado"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estadísticas Avanzadas 📈"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_primario"
                android:layout_marginBottom="16dp"/>

            <!-- Estadísticas Usuarios -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnVerEstadisticaUsuarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊"
                        android:textSize="30sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estadísticas de Usuarios"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_primario"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Análisis visual de roles"
                            android:textSize="12sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/verde_primario"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Estadísticas Productos -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnVerEstadisticaProductos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈"
                        android:textSize="30sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estadísticas de Productos"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_primario"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Análisis visual de inventario"
                            android:textSize="12sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="@color/verde_primario"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavAdmin"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutReportes"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/admin_nav_menu" />

    <ProgressBar
        android:id="@+id/progressReporte"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#25632D"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
