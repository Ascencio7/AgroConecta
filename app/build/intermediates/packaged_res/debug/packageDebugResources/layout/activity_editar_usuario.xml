<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorEditarUsuario"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutEditarUsuario"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/crema"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/verde_primario"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/ivHeaderLogoEditarUsuario"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/logoapp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Logo"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AgroConecta"
                    android:textColor="@color/blanco"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editar Información de Usuario"
                    android:textColor="#AAFFCC"
                    android:textSize="11sp"
                    android:textAllCaps="true"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="624dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:letterSpacing="0.05"
                            android:text="EDITAR PERFIL"
                            android:textColor="@color/verde_primario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="Nombre completo">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textColor="@color/texto_primario" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="Correo electrónico">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCorreo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"
                                android:textColor="@color/texto_primario" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:hint="Teléfono">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTelefono"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="phone"
                                android:textColor="@color/texto_primario" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="ROL DEL USUARIO"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spRol"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginBottom="24dp"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtEstadoLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Estado del usuario"
                                    android:textColor="@color/texto_primario"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Permitir acceso al sistema"
                                    android:textColor="@color/texto_tenue"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switchEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:thumbTint="@color/verde_primario"
                                app:trackTint="@color/verde_tenue" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="24dp"
                            android:background="#EEEEEE" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCancelar"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="54dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="CANCELAR"
                                android:textColor="@color/texto_secundario"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/crema_medio"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGuardar"
                                android:layout_width="0dp"
                                android:layout_height="54dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:text="ACTUALIZAR"
                                android:textColor="@color/blanco"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/verde_primario"
                                app:cornerRadius="14dp" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavAdmin"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutEditarUsuario"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/admin_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
