<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorAgregarEditar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutAgregarEditar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/crema"
        android:orientation="vertical"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/verde_primario"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/ivHeaderLogoAgregarEditarProducto"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="Logo"
                android:scaleType="fitCenter"
                android:src="@drawable/logoapp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AgroConecta"
                    android:textColor="@color/blanco"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gestionar Producto"
                    android:textColor="#AAFFCC"
                    android:textSize="11sp"
                    android:textAllCaps="true" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="120dp">

                <!-- DATOS PRINCIPALES -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="DATOS DEL PRODUCTO"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Nombre del producto">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Descripción">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDescripcion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="top"
                                android:inputType="textMultiLine"
                                android:minLines="3" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="CATEGORÍA"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spCategoria"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PRECIO Y STOCK -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="PRECIO Y EXISTENCIA"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputOutlined"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:hint="Precio ($)">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etPrecio"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputOutlined"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:hint="Existencia">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etExistencia"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- INFO ADICIONAL -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="INFORMACIÓN ADICIONAL"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="URL de imagen">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etImagenUrl"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/TextInputOutlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="ID Vendedor">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUsuarioId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- MÉTODOS DE PAGO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/blanco"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="MÉTODOS DE PAGO ACEPTADOS"
                            android:textColor="@color/texto_secundario"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbEfectivo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💵  Efectivo"
                            android:textSize="15sp"
                            android:textColor="@color/texto_primario"
                            app:buttonTint="@color/verde_primario"
                            android:paddingStart="8dp"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbTransferencia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🏦  Transferencia bancaria"
                            android:textSize="15sp"
                            android:textColor="@color/texto_primario"
                            app:buttonTint="@color/verde_primario"
                            android:paddingStart="8dp"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbTarjeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💳  Tarjeta (débito/crédito)"
                            android:textSize="15sp"
                            android:textColor="@color/texto_primario"
                            app:buttonTint="@color/verde_primario"
                            android:paddingStart="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- BOTONES FIJOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/crema"
            android:elevation="12dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/id_cancelar_btn"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="CANCELAR"
                android:textColor="@color/texto_secundario"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/crema_medio"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/id_guardar_btn"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="ACTUALIZAR"
                android:textColor="@color/blanco"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/verde_primario"
                app:cornerRadius="14dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavAdmin"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutAgregarEditar"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/admin_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>