<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/crema"
        android:paddingBottom="72dp">

        <!-- HEADER FIJO -->
        <LinearLayout
            android:id="@+id/headerMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/verde_primario"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/ivHeaderLogo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/logoapp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Logo"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Bienvenido!"
                    android:textColor="@color/blanco"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catálogo de productos"
                    android:textColor="#AAFFCC"
                    android:textSize="11sp"
                    android:textAllCaps="true"/>
            </LinearLayout>

            <!-- Badge carrito -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@+id/btnHeaderCarrito"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_carrito_header"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Carrito"
                    android:padding="8dp"
                    app:tint="@color/blanco"/>
                <TextView
                    android:id="@+id/tvCarritoBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:gravity="center"
                    android:text="0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/carbon"
                    android:background="@drawable/bg_boton_dorado"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Avatar (FrameLayout para superponer foto e inicial) -->
            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="U"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/carbon"
                    android:background="@drawable/bg_avatar_circle"/>

                <ImageView
                    android:id="@+id/ivAvatarFoto"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:visibility="gone"
                    android:contentDescription="Foto de perfil"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ÁREA DE CONTENIDO -->
        <FrameLayout
            android:id="@+id/frameContenido"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- BOTTOM NAVIGATION BAR -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutMain"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/bottom_nav_menu" />

    <!-- CHAT FLOTANTE -->
    <include layout="@layout/chat_flotante"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
