<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorVendedor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutVendedor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/crema"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/verde_primario"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/ivHeaderLogoVendedor"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/logoapp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Logo"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvWelcomeVendedor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Bienvenido!"
                    android:textColor="@color/blanco"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tvVendedorNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vendedor - AgroConecta"
                    android:textColor="#AAFFCC"
                    android:textSize="11sp"
                    android:textAllCaps="true"/>
            </LinearLayout>

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/tvAvatarVendedor"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="U"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/carbon"
                    android:background="@drawable/bg_avatar_circle"/>
                <ImageView
                    android:id="@+id/ivAvatarFotoVendedor"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:visibility="gone"
                    android:contentDescription="Foto de perfil"/>
            </FrameLayout>
        </LinearLayout>

        <!-- CONTENIDO -->
        <FrameLayout
            android:id="@+id/panelContenedorVendedor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Mis Productos -->
            <LinearLayout
                android:id="@+id/panelMisProductos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp">

                    <androidx.appcompat.widget.SearchView
                        android:id="@+id/searchMisProductos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:background="@drawable/bg_search"
                        android:focusable="true"
                        android:clickable="true"
                        app:iconifiedByDefault="false"
                        app:queryHint="Buscar mis productos..."
                        app:searchIcon="@android:drawable/ic_menu_search"
                        app:queryBackground="@null"/>
                </LinearLayout>

                <!-- STATS COMPACTAS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp"
                        android:gravity="center"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:id="@+id/tvTotalProductos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/verde_primario"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total" android:textSize="10sp" android:textColor="@color/texto_tenue"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="#EEEEEE"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:id="@+id/tvProductosActivos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/exito"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Disponibles" android:textSize="10sp" android:textColor="@color/texto_tenue"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="#EEEEEE"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:id="@+id/tvProductosAgotados" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/rojo_error"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Agotados" android:textSize="10sp" android:textColor="@color/texto_tenue"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- FILTROS COMPACTOS (Chips) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFiltroTodosV"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Todos"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="18dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFiltroActivosV"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Disponibles"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="18dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFiltroNoDispV"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="No Disponibles"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="18dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFiltroAgotadosV"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Agotados"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            app:cornerRadius="18dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
    <ProgressBar
        android:id="@+id/progressProductosVendedor"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/verde_primario"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvEmptyProductosVendedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="No tienes productos publicados aún"
        android:textColor="@color/texto_secundario"
        android:textSize="15sp"
        android:visibility="gone"/>



                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMisProductos"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingBottom="16dp"
                        android:clipToPadding="false"/>

                    <TextView
                        android:id="@+id/tvNoResultadosVendedor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="No se encontraron productos"
                        android:textColor="@color/texto_tenue"
                        android:textSize="16sp"
                        android:visibility="gone"
                        android:paddingBottom="100dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelMisPedidosVendedor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Filtro por Estado -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado:"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginEnd="10dp"/>

                        <Spinner
                            android:id="@+id/spFiltroEstadoPedido"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_input"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <ProgressBar
                    android:id="@+id/progressPedidosVendedor"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/verde_primario"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvEmptyPedidosVendedor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="No tienes pedidos aún"
        android:textColor="@color/texto_secundario"
        android:textSize="15sp"
        android:visibility="gone"/>



                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPedidosVendedor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:clipToPadding="false"/>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavVendedor"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutVendedor"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/seller_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
