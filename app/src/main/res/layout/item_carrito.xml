<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Imagen -->
        <androidx.cardview.widget.CardView
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/crema_medio">

            <ImageView
                android:id="@+id/ivImagenCarrito"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"/>
        </androidx.cardview.widget.CardView>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreCarrito"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/texto_primario"
                android:text="Nombre"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvPrecioCarrito"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/texto_tenue"
                android:textSize="12sp"
                android:text="$0.00 c/u"
                android:layout_marginBottom="8dp"/>

            <!-- Controles cantidad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Selector cantidad con fondo verde suave -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#E8F5E9"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:id="@+id/btnMenos"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="−"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/verde_primario"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/tvCantidadCarrito"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/texto_primario"
                        android:gravity="center"
                        android:text="1"/>

                    <TextView
                        android:id="@+id/btnMas"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="+"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/verde_primario"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Subtotal -->
                <TextView
                    android:id="@+id/tvSubtotalCarrito"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="@color/verde_primario"
                    android:text="$0.00"
                    android:gravity="end"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Botón eliminar -->
        <ImageButton
            android:id="@+id/btnEliminarCarrito"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@color/rojo_tenue"
            android:padding="7dp"
            android:layout_marginStart="8dp"
            android:layout_gravity="top"
            android:contentDescription="Eliminar"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
