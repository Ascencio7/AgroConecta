<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorAgregarProducto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutAddProductoVendedor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/crema"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/verde_primario"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/ivHeaderLogoAddProducto"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/logoapp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Logo"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AgroConecta"
                    android:textColor="@color/blanco"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvTituloFormVendedor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agregar Producto"
                    android:textColor="#AAFFCC"
                    android:textSize="11sp"
                    android:textAllCaps="true"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvAvatarVendedorAdd"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="U"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/carbon"
                    android:background="@drawable/bg_avatar_circle"/>

                <ImageView
                    android:id="@+id/ivAvatarFotoVendedorAdd"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle"
                    android:visibility="gone"
                    android:contentDescription="Foto de perfil"/>
            </FrameLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📦  INFORMACIÓN DEL PRODUCTO" android:textSize="11sp" android:letterSpacing="0.08" android:textStyle="bold" android:textColor="@color/verde_primario" android:layout_marginBottom="14dp"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nombre del producto" android:layout_marginBottom="12dp" style="@style/TextInputOutlined">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVNombre" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="textCapWords"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Descripción" android:layout_marginBottom="12dp" style="@style/TextInputOutlined">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVDescripcion" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textMultiLine" android:minLines="3"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:baselineAligned="false">
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Precio ($)" android:layout_marginEnd="8dp" style="@style/TextInputOutlined">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVPrecio" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="numberDecimal"/>
                            </com.google.android.material.textfield.TextInputLayout>
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Existencia" android:layout_marginStart="8dp" style="@style/TextInputOutlined">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVExistencia" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="number"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Foto del producto" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/texto_secundario" android:layout_marginBottom="6dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivFotoProducto" android:layout_width="80dp" android:layout_height="80dp" android:scaleType="centerCrop" android:background="@color/crema" android:src="@drawable/ic_launcher_foreground" android:contentDescription="Foto"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                                <com.google.android.material.button.MaterialButton android:id="@+id/btnTomarFoto" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📷  Tomar foto" android:textColor="@color/blanco" android:backgroundTint="@color/verde_primario" android:textSize="13sp" android:layout_marginBottom="6dp" style="@style/BtnPrimario"/>
                                <com.google.android.material.button.MaterialButton android:id="@+id/btnElegirGaleria" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🖼️  Elegir de galería" android:textColor="@color/negro" android:textSize="13sp" android:backgroundTint="@color/verde_superficial" style="@style/BtnSecundario"/>
                            </LinearLayout>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Categoría" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/texto_secundario" android:layout_marginBottom="6dp"/>
                        <Spinner android:id="@+id/spVCategoria" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_input" android:paddingHorizontal="12dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📍  UBICACIÓN DE VENTA" android:textSize="11sp" android:letterSpacing="0.08" android:textStyle="bold" android:textColor="@color/verde_primario" android:layout_marginBottom="14dp"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Dirección o referencia" android:layout_marginBottom="12dp" style="@style/TextInputOutlined">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVDireccion" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="textPostalAddress"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <Button
                            android:id="@+id/btnUsarMiUbicacion"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="📍  Usar mi ubicación actual"
                            android:textColor="@color/negro"
                            android:backgroundTint="@color/verde_superficial"
                            android:layout_marginBottom="10dp"
                            style="@style/BtnSecundario"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Latitud" android:layout_marginEnd="8dp" style="@style/TextInputOutlined">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVLatitud" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="numberDecimal|numberSigned" android:enabled="false"/>
                            </com.google.android.material.textfield.TextInputLayout>
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Longitud" android:layout_marginStart="8dp" style="@style/TextInputOutlined">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVLongitud" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="numberDecimal|numberSigned" android:enabled="false"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                        <TextView android:id="@+id/tvUbicacionStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sin ubicación seleccionada" android:textSize="12sp" android:textColor="@color/texto_tenue" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📞  FORMAS DE CONTACTO" android:textSize="11sp" android:letterSpacing="0.08" android:textStyle="bold" android:textColor="@color/verde_primario" android:layout_marginBottom="14dp"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="WhatsApp / Teléfono" android:layout_marginBottom="12dp" style="@style/TextInputOutlined">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etVTelefono" android:layout_width="match_parent" android:layout_height="56dp" android:inputType="phone"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💳  MÉTODOS DE PAGO ACEPTADOS" android:textSize="11sp" android:letterSpacing="0.08" android:textStyle="bold" android:textColor="@color/verde_primario" android:layout_marginBottom="14dp"/>
                        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbEfectivo" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💵  Efectivo" android:textSize="15sp" android:textColor="@color/texto_primario" app:buttonTint="@color/verde_primario" android:checked="true" android:paddingStart="8dp" android:layout_marginBottom="8dp"/>
                        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbTransferencia" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🏦  Transferencia bancaria" android:textSize="15sp" android:textColor="@color/texto_primario" app:buttonTint="@color/verde_primario" android:paddingStart="8dp" android:layout_marginBottom="8dp"/>
                        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/cbTarjeta" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💳  Tarjeta (débito/crédito)" android:textSize="15sp" android:textColor="@color/texto_primario" app:buttonTint="@color/verde_primario" android:paddingStart="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="32dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancelarProductoV"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="CANCELAR"
                        android:textStyle="bold"
                        android:textColor="@color/texto_secundario"
                        android:textSize="13sp"
                        app:backgroundTint="@color/crema_medio"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPublicarProducto"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="ACTUALIZAR"
                        android:textColor="@color/blanco"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/verde_primario"
                        app:cornerRadius="14dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavVendedorAdd"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutAddProductoVendedor"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/seller_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>