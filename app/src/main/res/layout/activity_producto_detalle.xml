<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verde_primario"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/linearLayoutProductoDetalle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="72dp">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/verde_primario"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnBackDetalle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/blanco"
                android:contentDescription="Volver"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Detalle del Producto"
                android:textColor="@color/blanco"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CONTENIDO -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivImagenDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/blanco">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:id="@+id/tvNombreDetalle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_primario"
                            android:text="Nombre del Producto"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvCategoriaDetalle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/blanco"
                            android:background="@drawable/bg_badge_verde"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Categoría"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@color/verde_superficial"
                                android:padding="12dp"
                                android:layout_marginEnd="6dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PRECIO"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/verde_primario"/>
                                <TextView
                                    android:id="@+id/tvPrecioDetalle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="26sp"
                                    android:textColor="@color/verde_primario"
                                    android:textStyle="bold"
                                    android:text="$0.00"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@color/crema"
                                android:padding="12dp"
                                android:layout_marginStart="6dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DISPONIBILIDAD"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/texto_secundario"/>
                                <TextView
                                    android:id="@+id/tvStockDetalle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/texto_primario"
                                    android:text="0 disponibles"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DESCRIPCIÓN"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_tenue"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvDescripcionDetalle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="@color/texto_secundario"
                            android:lineSpacingMultiplier="1.2"
                            android:text="Descripción del producto"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/crema"
                            android:padding="12dp"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CANTIDAD"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/texto_secundario"
                                android:layout_marginEnd="16dp"/>
                            <ImageButton
                                android:id="@+id/btnMenosCantidad"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/btn_minus"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/verde_primario"/>
                            <TextView
                                android:id="@+id/tvCantidadDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="20dp"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/texto_primario"
                                android:text="1"/>
                            <ImageButton
                                android:id="@+id/btnMasCantidad"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/btn_plus"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/verde_primario"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAgregarCarrito"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="AGREGAR AL CARRITO"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/blanco"
                            app:backgroundTint="@color/verde_primario"
                            app:cornerRadius="16dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- VENDEDOR -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:layout_marginTop="0dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/blanco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VENDEDOR"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/texto_tenue"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <FrameLayout
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:layout_marginEnd="16dp">
                                <TextView
                                    android:id="@+id/tvAvatarVendedorDetalle"
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:gravity="center"
                                    android:text="V"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/carbon"
                                    android:background="@drawable/bg_avatar_circle"/>
                                <ImageView
                                    android:id="@+id/ivFotoVendedorDetalle"
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:scaleType="centerCrop"
                                    android:background="@drawable/bg_avatar_circle"
                                    android:visibility="gone"
                                    android:contentDescription="Foto vendedor"/>
                            </FrameLayout>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvNombreVendedorDetalle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Cargando..."
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/texto_primario"/>
                                <TextView
                                    android:id="@+id/tvTelefonoVendedorDetalle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📞 No disponible"
                                    android:textSize="13sp"
                                    android:textColor="@color/texto_tenue"/>
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/rowDireccion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📍 " android:textSize="14sp"/>
                            <TextView
                                android:id="@+id/tvDireccionVendedorDetalle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="13sp"
                                android:textColor="@color/texto_secundario"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvMetodosPagoDetalle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💵 Efectivo"
                            android:textSize="13sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginBottom="20dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnContactarVendedor"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="WhatsApp"
                                android:textColor="@color/blanco"
                                android:textSize="13sp"
                                app:backgroundTint="#25D366"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/stat_sys_phone_call"
                                app:iconSize="18dp"
                                app:iconGravity="textStart"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnVerUbicacion"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="Mapa"
                                android:textColor="@color/verde_primario"
                                android:textSize="13sp"
                                app:backgroundTint="@color/verde_superficial"
                                app:strokeColor="@color/verde_primario"
                                app:strokeWidth="1dp"
                                app:cornerRadius="12dp"
                                app:icon="@android:drawable/ic_dialog_map"
                                app:iconSize="18dp"
                                app:iconGravity="textStart"
                                app:iconTint="@color/verde_primario"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- BARRA DE NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        style="@style/Widget.App.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/blanco"
        android:elevation="14dp"
        app:labelVisibilityMode="labeled"
        app:layout_anchor="@+id/linearLayoutProductoDetalle"
        app:layout_anchorGravity="bottom|center"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
