<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Panel de chat -->
    <androidx.cardview.widget.CardView
        android:id="@+id/panelChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="84dp"
        android:layout_marginHorizontal="12dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/blanco">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/verde_primario"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="🤖"
                    android:textSize="20sp"
                    android:background="@drawable/bg_avatar_circle"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Asistente AgroConecta"
                    android:textColor="@color/blanco"
                    android:textStyle="bold"
                    android:textSize="15sp"/>

                <ImageButton
                    android:id="@+id/btnCerrarChat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Cerrar"
                    app:tint="@color/blanco"/>
            </LinearLayout>

            <!-- Mensajes -->
            <ScrollView
                android:id="@+id/scrollChat"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/crema"
                android:padding="12dp">
                <LinearLayout
                    android:id="@+id/contenedorMensajes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

            <!-- Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:background="@color/blanco"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etMensaje"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:hint="Pregunta algo..."
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="3"
                    android:importantForAutofill="no"/>

                <ImageButton
                    android:id="@+id/btnEnviar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:background="@drawable/bg_boton_verde"
                    android:padding="10dp"
                    app:tint="@color/blanco"
                    android:contentDescription="Enviar"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FAB Asistente -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_dialog_info"
        app:backgroundTint="@color/dorado_medio"
        app:tint="@color/carbon"
        app:elevation="8dp"
        android:contentDescription="Asistente IA"/>

</RelativeLayout>
