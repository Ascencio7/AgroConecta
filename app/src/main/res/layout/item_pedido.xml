<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/blanco"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gris_borde">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila 1: ID + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvPedidoId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pedido #0000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_primario"/>

            <TextView
                android:id="@+id/tvPedidoEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/exito"
                android:background="@drawable/bg_badge_verde"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- Fila 2: Productos -->
        <TextView
            android:id="@+id/tvPedidoItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Productos del pedido"
            android:textSize="13sp"
            android:textColor="@color/texto_secundario"
            android:layout_marginBottom="10dp"
            android:lineSpacingMultiplier="1.4"/>

        <!-- Fila 3: Total + Fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvPedidoTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$0.00"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/verde_primario"/>

            <TextView
                android:id="@+id/tvPedidoFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Hoy"
                android:textSize="12sp"
                android:textColor="@color/texto_tenue"/>
        </LinearLayout>

        <!-- Fila 4: Botones centrados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSeguimiento"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📦 Seguimiento"
                android:textSize="12sp"
                android:textColor="@color/verde_primario"
                android:backgroundTint="@color/verde_superficial"
                android:strokeColor="@color/verde_primario"
                android:strokeWidth="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalificar"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⭐ Calificar"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C8861A"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
