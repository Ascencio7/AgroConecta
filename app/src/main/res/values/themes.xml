<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="TextViewUppercase" parent="android:Widget.TextView">
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Base.Theme.AgroConecta" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/verde_primario</item>
        <item name="colorPrimaryVariant">@color/verde_oscuro</item>
        <item name="colorOnPrimary">@color/blanco</item>
        <item name="colorSecondary">@color/dorado_medio</item>
        <item name="colorOnSecondary">@color/texto_primario</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/texto_primario</item>
        <item name="android:colorBackground">@color/crema</item>
        <item name="colorError">@color/rojo_error</item>
        <item name="android:statusBarColor">@color/verde_primario</item>
        <item name="android:navigationBarColor">@color/blanco</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowTranslucentStatus">false</item>

        <item name="android:textAllCaps">true</item>
        <item name="android:textViewStyle">@style/TextViewUppercase</item>
        <item name="android:editTextStyle">@style/TextViewUppercase</item>
        <item name="android:buttonStyle">@style/BtnPrimario</item>
        <item name="materialButtonStyle">@style/BtnPrimario</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
        <!-- TextInputLayout colores -->
        <item name="textInputStyle">@style/TextInputOutlined</item>
    </style>

    <style name="Theme.AgroConecta" parent="Base.Theme.AgroConecta"/>

    <!-- Shapes -->
    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">10dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="HintUppercase" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- TextInput mejorado -->
    <style name="TextInputOutlined" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/verde_primario</item>
        <item name="hintTextColor">@color/verde_primario</item>
        <item name="boxBackgroundColor">@color/blanco</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="hintTextAppearance">@style/HintUppercase</item>
    </style>

    <!-- Botón primario -->
    <style name="BtnPrimario" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/verde_primario</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Botón secundario -->
    <style name="BtnSecundario" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/verde_primario</item>
        <item name="android:textColor">@color/verde_primario</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Botón peligro -->
    <style name="BtnPeligro" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/rojo_error</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- CardView mejorado -->
    <style name="CardMejorado" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/blanco</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/gris_borde</item>
    </style>

    <!-- Toolbar mejorado -->
    <style name="ToolbarAgroConecta" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/verde_primario</item>
        <item name="titleTextColor">@color/blanco</item>
        <item name="navigationIconTint">@color/blanco</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- BottomNav Restaurado al código funcional -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemIconSize">22dp</item>
        <item name="android:background">@color/blanco</item>
        <item name="backgroundTint">@color/blanco</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
</resources>
