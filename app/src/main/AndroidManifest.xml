<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permiso de internet -->
        <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Declara la camara como opcional para que funcione en emuladores -->
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <uses-feature android:name="android.hardware.camera.front" android:required="false"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Android 11+ necesita declarar los intents que va a resolver -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK"/>
            <data android:mimeType="image/*"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT"/>
            <data android:mimeType="image/*"/>
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AgroConecta"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Login como pantalla inicial -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Usuarios Activity -->
        <activity android:name=".ui.UsuarioActivity"
            android:exported="false"
            android:label="Usuarios" />

        <!-- Panel de vistas del Administrador Activity -->
        <activity android:name=".ui.AdminDashboardActivity"
            android:exported="false"
            android:label="Admin" />

        <!-- Gestión de Productos para Admin -->
        <activity android:name=".ui.ProductosAdminActivity"
            android:exported="false"
            android:label="Gestión de Productos" />

        <activity android:name=".ui.AgregarEditarProductoActivity"
            android:exported="false"
            android:label="Producto" />

        <!-- Reportes Activity -->
        <activity android:name=".ui.ReportesActivity"
            android:exported="false"
            android:label="Reportes" />

        <!-- Términos y Condiciones Activity -->
        <activity android:name=".ui.TermsActivity"
            android:exported="false"
            android:label="Términos y Condiciones" />

        <!-- Registro de Usuarios Activity -->
        <activity android:name=".ui.RegisterActivity"
            android:exported="false"
            android:label="Registrarse"/>

        <!-- Editar Usuario Activity -->
        <activity android:name=".ui.EditarUsuarioActivity"
            android:exported="false"
            android:label="Editar"/>

        <!-- Crear Usuario Activity -->
        <activity android:name=".ui.CrearUsuarioActivity"
            android:exported="false"
            android:label="Crear"/>

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <!-- Buyer Module Activity -->
        <activity
            android:name=".ui.BuyerModuleActivity"
            android:label="Módulo Comprador"
            android:exported="false" />

        <!-- Mapa Activity -->
        <activity
            android:name=".ui.MapaActivity"
            android:exported="false"
            android:label="Mapa de Fincas"/>

        <!-- Módulo Comprador - CRUD -->
        <activity
            android:name=".ui.ProductoDetalleActivity"
            android:exported="false"
            android:label="Detalle Producto"/>

        <activity
            android:name=".ui.CarritoActivity"
            android:exported="false"
            android:label="Mi Carrito"/>

        <activity
            android:name=".ui.MisPedidosActivity"
            android:exported="false"
            android:label="Mis Pedidos"/>

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyAkKvBXZo39gk1fqnxVJ7PCd0UVECRT7kI"/>

        <service
            android:name=".service.AgroConectaFirebaseService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="canal_productos"/>

    
        <!-- Vendedor -->
        <activity android:name=".ui.VendedorDashboardActivity"
            android:exported="true" />
        <activity android:name=".ui.AgregarProductoVendedorActivity"
            android:exported="false" />
        <activity android:name=".ui.ContactarVendedorActivity"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <!-- Chat en tiempo real -->
        <activity android:name=".ui.ChatActivity" android:exported="false"/>

        <!-- Calificaciones -->
        <activity android:name=".ui.CalificacionActivity" android:exported="false"/>

        <!-- Seguimiento de pedido -->
        <activity android:name=".ui.SeguimientoPedidoActivity" android:exported="false"/>

        <!-- FCM Service -->
        <service
            android:name=".service.AgroConectaFirebaseService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>
</application>

</manifest>